<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:misc="clr-namespace:Zafiro.Avalonia.Misc;assembly=Zafiro.Avalonia"
             x:Class="FIFOCalculator.App"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <misc:DataTemplateInclude Source="avares://Zafiro.Avalonia/DataTemplates.axaml" />
        <DataTypeViewLocator />
        <NamingConventionGeneratedViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
        <StyleInclude Source="avares://Zafiro.Avalonia/Styles.axaml"/>
        <StyleInclude Source="Controls/SvgButton.axaml"/>

        <Style Selector="HeaderedContentControl.CenteredHeader">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <StackPanel>
                                <ContentPresenter Margin="0 4" HorizontalAlignment="Center"
                                                  Content="{TemplateBinding Header}" FontWeight="Bold" />
                                <ContentPresenter Content="{TemplateBinding Content}" />
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style Selector="HeaderedContentControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate>
                        <StackPanel>
                            <ContentPresenter Margin="0 4" Content="{TemplateBinding Header}" FontWeight="Bold" />
                            <ContentPresenter Content="{TemplateBinding Content}" />
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Styles>

</Application>
